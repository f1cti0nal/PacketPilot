*.tsbuildinfo

# Tauri / Rust
src-tauri/target
src-tauri/gen
src-tauri/Cargo.lock

# src/wasm/ is intentionally COMMITTED (not ignored) so Vercel git push-to-deploy
# can run `npm run build` (tsc + vite) WITHOUT the Rust/wasm-bindgen toolchain it
# lacks. Regenerate AND re-commit it whenever engine/crates/ppcap-wasm changes:
#   cd ui && npm run build:wasm   (then git add src/wasm && commit)
# Throwaway capture used only for local wasm verification
public/test/

# Vitest coverage report (regenerable via npm run test:coverage)
coverage

# Playwright E2E artifacts (regenerable via npm run e2e)
test-results
playwright-report
blob-report
playwright/.cache
# Editor launch/scratch config
.claude
