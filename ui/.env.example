# Supabase (public, safe to expose in the browser bundle).
# Copy to ui/.env.local and fill in from the Supabase project settings.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Analytics 4 measurement id (e.g. G-XXXXXXXXXX). Optional — leave blank to fully
# disable GA (no script loads, no consent banner). GA is hard opt-in: even when set, nothing
# is sent to Google until the visitor accepts the consent banner.
VITE_GA_MEASUREMENT_ID=
