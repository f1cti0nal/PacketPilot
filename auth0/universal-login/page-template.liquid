{% assign resolved_dir = dir | default: "auto" %}
<!DOCTYPE html>
<html lang="{{ locale }}" dir="{{ resolved_dir }}">
  <head>
    {%- auth0:head -%}
    <!--
      PacketPilot — Auth0 Universal Login page template (New Universal Login / Liquid).
      This template draws the SURROUND only: the split-screen layout, the branding panel,
      and the page background. The login box itself ({%- auth0:widget -%}) is styled by the
      Universal Login THEME (see theme.json) — never hand-CSS Auth0's internal widget classes,
      they are regenerated on every build and any selector targeting them will silently break.
      Requires a Custom Domain on the tenant (page templates are gated on it). See README.md.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        /* Slate-navy surfaces + enterprise-blue accent — mirrors ui/src/index.css */
        --pp-bg: #0b1220;
        --pp-panel-a: #0e1a2c;
        --pp-panel-b: #0b1220;
        --pp-border: #223049;
        --pp-border-strong: #2c3c58;
        --pp-text: #e7edf7;
        --pp-text-dim: #93a1b7;
        --pp-text-faint: #8b98ad;
        --pp-accent: #60a5fa;
        --pp-accent-strong: #93c5fd;
        --pp-accent-deep: #1d4ed8;
        --pp-violet: #7c5cff;
        /* Auth0 login-box width hook (default 400px). */
        --prompt-width: 400px;
      }

      * { box-sizing: border-box; }
      html, body { height: 100%; }
      body {
        margin: 0;
        background: var(--pp-bg);
        color: var(--pp-text);
        font-family: "Geist", ui-sans-serif, system-ui, -apple-system, "Segoe UI",
          Roboto, Helvetica, Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .pp-auth {
        min-height: 100vh;
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1.08fr);
      }

      /* ── Left: the Auth0 widget column ─────────────────────────────────────
         margin-block:auto centers the group when it fits and collapses to 0 when
         the prompt is taller than the viewport (MFA enrol, long signup) so the top
         stays reachable and the page scrolls — avoids the flex "justify-center" clip. */
      .pp-auth__form {
        position: relative;
        display: flex;
        flex-direction: column;
        padding: 48px 24px;
        background:
          radial-gradient(900px 480px at 50% -12%,
            color-mix(in srgb, var(--pp-accent) 6%, transparent), transparent 60%),
          var(--pp-bg);
      }
      .pp-auth__inner {
        margin-block: auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 26px;
        width: 100%;
      }
      .pp-auth__logo {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--pp-text);
        text-decoration: none;
        font-weight: 600;
        font-size: 19px;
        letter-spacing: -0.01em;
      }
      .pp-auth__logo svg { color: var(--pp-accent); }

      /* ── Right: PacketPilot branding panel (decorative; hidden on narrow screens) ── */
      .pp-auth__brand {
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 24px;
        padding: 64px clamp(40px, 5vw, 72px);
        border-left: 1px solid var(--pp-border);
        background: linear-gradient(158deg, var(--pp-panel-a) 0%, var(--pp-panel-b) 62%);
      }
      .pp-auth__brand::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
          radial-gradient(680px 420px at 84% 6%,
            color-mix(in srgb, var(--pp-accent) 16%, transparent), transparent 60%),
          radial-gradient(520px 360px at 8% 112%,
            color-mix(in srgb, var(--pp-violet) 12%, transparent), transparent 55%);
      }
      .pp-auth__brand > * { position: relative; z-index: 1; }

      .pp-brand-logo {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        color: var(--pp-text);
        font-weight: 600;
        font-size: 20px;
        letter-spacing: -0.01em;
      }
      .pp-brand-logo svg { color: var(--pp-accent); }
      .pp-brand-h {
        margin: 4px 0 0;
        font-size: clamp(28px, 3vw, 36px);
        line-height: 1.12;
        font-weight: 600;
        letter-spacing: -0.02em;
        max-width: 16ch;
      }
      .pp-brand-h em { font-style: normal; color: var(--pp-accent); }
      .pp-brand-sub {
        margin: 0;
        font-size: 16px;
        line-height: 1.62;
        color: var(--pp-text-dim);
        max-width: 48ch;
      }
      .pp-feats {
        list-style: none;
        padding: 0;
        margin: 4px 0 0;
        display: flex;
        flex-direction: column;
        gap: 13px;
      }
      .pp-feat {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        font-size: 14.5px;
        line-height: 1.5;
        color: var(--pp-text);
      }
      .pp-feat svg { flex: none; margin-top: 2px; color: var(--pp-accent); }
      .pp-privacy {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        align-self: flex-start;
        margin-top: 4px;
        padding: 9px 14px;
        border: 1px solid var(--pp-border-strong);
        border-radius: 9999px;
        background: color-mix(in srgb, var(--pp-accent) 8%, transparent);
        color: var(--pp-accent-strong);
        font-size: 13px;
        font-weight: 500;
      }
      .pp-privacy svg { color: var(--pp-accent); }
      .pp-brand-foot {
        margin-top: 6px;
        font-size: 12.5px;
        color: var(--pp-text-faint);
      }

      @media (max-width: 900px) {
        .pp-auth { grid-template-columns: 1fr; }
        .pp-auth__brand { display: none; }
      }
      @media (prefers-reduced-motion: reduce) {
        * { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
      }
    </style>
  </head>

  <body>
    <main class="pp-auth">
      <!-- LEFT: Auth0-rendered login box, with the PacketPilot mark above it. -->
      <section class="pp-auth__form">
        <div class="pp-auth__inner">
          <a class="pp-auth__logo" href="https://packetpilot.app" aria-label="PacketPilot home">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="1.2" opacity="0.3"/>
              <circle cx="12" cy="12" r="7" stroke="currentColor" stroke-width="1.2" opacity="0.5"/>
              <circle cx="12" cy="12" r="3.2" stroke="currentColor" stroke-width="1.2"/>
              <line x1="12" y1="1" x2="12" y2="23" stroke="currentColor" stroke-width="1" opacity="0.18"/>
              <line x1="1" y1="12" x2="23" y2="12" stroke="currentColor" stroke-width="1" opacity="0.18"/>
              <circle cx="12" cy="4.5" r="1.6" fill="currentColor"/>
              <circle cx="12" cy="12" r="1.6" fill="currentColor"/>
            </svg>
            <span>PacketPilot</span>
          </a>
          {%- auth0:widget -%}
        </div>
      </section>

      <!-- RIGHT: branding panel. aria-hidden so screen readers land straight on the form. -->
      <aside class="pp-auth__brand" aria-hidden="true">
        <div class="pp-brand-logo">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="1.2" opacity="0.3"/>
            <circle cx="12" cy="12" r="7" stroke="currentColor" stroke-width="1.2" opacity="0.5"/>
            <circle cx="12" cy="12" r="3.2" stroke="currentColor" stroke-width="1.2"/>
            <line x1="12" y1="1" x2="12" y2="23" stroke="currentColor" stroke-width="1" opacity="0.18"/>
            <line x1="1" y1="12" x2="23" y2="12" stroke="currentColor" stroke-width="1" opacity="0.18"/>
            <circle cx="12" cy="4.5" r="1.6" fill="currentColor"/>
            <circle cx="12" cy="12" r="1.6" fill="currentColor"/>
          </svg>
          <span>PacketPilot</span>
        </div>

        <h1 class="pp-brand-h">Turn a <em>.pcap</em> into ranked threat intelligence.</h1>

        <p class="pp-brand-sub">
          {% if prompt.name == "signup" or prompt.name == "signup-id" or prompt.name == "signup-password" %}
            Create your account to save workspaces and unlock reputation + AI enrichment.
            Your captures still never leave the browser.
          {% else %}
            A Rust + WebAssembly engine triages your capture on-device — severity-ranked,
            MITRE ATT&amp;CK&#8211;mapped findings without a packet ever leaving your browser.
          {% endif %}
        </p>

        <ul class="pp-feats">
          <li class="pp-feat">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10.5l3.5 3.5L16 5.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>20+ detectors — beaconing, exfiltration, scans, lateral movement, and more.</span>
          </li>
          <li class="pp-feat">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10.5l3.5 3.5L16 5.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Every finding severity-ranked and mapped to MITRE ATT&amp;CK.</span>
          </li>
          <li class="pp-feat">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M4 10.5l3.5 3.5L16 5.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Runs entirely on your device — nothing is uploaded, and it works offline.</span>
          </li>
        </ul>

        <span class="pp-privacy">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 1.5l5 2v3.2c0 3.2-2.1 5.9-5 6.8-2.9-0.9-5-3.6-5-6.8V3.5l5-2z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><path d="M5.7 8l1.6 1.6L10.5 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Your captures never leave the browser
        </span>

        <p class="pp-brand-foot">PacketPilot &middot; In-browser PCAP threat triage</p>
      </aside>
    </main>
  </body>
</html>
